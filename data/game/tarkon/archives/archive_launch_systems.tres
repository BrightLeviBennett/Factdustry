script = ExtResource("1")
id = &"archive_launch_systems"
display_name = "Archive: Launch Systems"
description = "After realizing that they have had a few too many close calls when doing their battles, The Primatives decided to make this well engineered set of blocks to distribute items from one sector to another to not need to worry about running low on resources again."
