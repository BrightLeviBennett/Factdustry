[resource]
script = ExtResource("1")
id = &"ground_scraper"
display_name = "Ground Scraper"
description = "Industrial surface miner that strips topsoil for sand and ores like coal. Produces 1 item every 2 seconds at baseline; each extra valid tile under the footprint adds +25% throughput. Only mines floor-borne deposits — wall ores are out of reach."
icon = ExtResource("2_gscom")
category = 1
tags = PackedStringArray("mining", "extraction", "floor_miner", "scraper_head", "omnidirectional")
color = Color(0.5, 0.6, 0.3, 1)
grid_size = Vector2i(2, 2)
top_sprite = ExtResource("3_gsbas")
max_health = 320.0
build_cost = {
"copper": 50,
"silicon": 30
}
build_time = 4.0
production_time = 2.0
accepted_ores = Array[StringName]([&"coal_ore", &"sulfur_ore"])
electrical_power_use = 10.0
max_stored_items = 10
