[resource]
script = ExtResource("1")
id = &"spritz"
display_name = "Spritz"
description = "Rapid-fire fluid sprayer. Accepts water, salt water, slag, petroleum, heavy fuel, oxygen, or hydrogen. Oxygen and hydrogen build a lingering gas cloud at the impact: hydrogen poisons + slows enemies inside; oxygen is flammable and bursts into fire when a Flarecaster's flame sweeps through it. Water auto-douses nearby fires; slag + petroleum on the same target doubles the slag's burn."
icon = ExtResource("4_icon")
category = 4
tags = PackedStringArray("turret", "defense")
color = Color(0.45, 0.75, 1.0, 1)
base_sprite = ExtResource("2_base")
turret_head_sprite = ExtResource("3_head")
max_health = 220.0
build_cost = {
"copper": 80,
"silicon": 30
}
build_time = 3.0
electrical_power_use = 3.0
attack_speed = 0.25
attack_range = 5.5
ammo_types = Array[Resource]([SubResource("Ammo_water"), SubResource("Ammo_salt_water"), SubResource("Ammo_slag"), SubResource("Ammo_petroleum"), SubResource("Ammo_heavy_fuel"), SubResource("Ammo_oxygen"), SubResource("Ammo_hydrogen")])
liquid_capacity = 40.0
max_stored_items = 30
