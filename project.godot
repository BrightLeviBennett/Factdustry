; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Factdustry"
run/main_scene="res://main/MainMenu.tscn"
config/auto_accept_quit=false
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

Registry="*uid://b0tpm8c8hjplm"
SaveManager="*uid://bulxqckxs21bm"
TechTree="*uid://skp78ngoxv7k"

[display]

window/size/viewport_width=1500
window/size/viewport_height=1050
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/manifest_builder/plugin.cfg")

